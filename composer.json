{
  "name": "y0lk/jobby",
  "homepage": "https://github.com/Y0lk/jobby",
  "license": "MIT",
  "type": "library",
  "description": "Manage all your cron jobs without modifying crontab. Handles locking, logging, error emails, and more.",
  "authors": [
    {
      "name": "Gabriel Jean",
      "email": "gab@inkrebit.com",
      "homepage": "https://github.com/Y0lk",
      "role": "Maintainer"
    },
    {
      "name": "Gerard Sychay",
      "email": "hellogerard@gmail.com",
      "homepage": "https://github.com/hellogerard",
      "role": "Original author"
    },
    {
      "name": "Michael Contento",
      "homepage": "https://github.com/michaelcontento",
      "role": "Contributor"
    }
  ],
  "keywords": [
    "cron",
    "scheduler",
    "jobs",
    "cli"
  ],
  "require": {
    "php": "^8.0",
    "dragonmantank/cron-expression": "^3.0",
    "opis/closure": "^4.5",
    "phpmailer/phpmailer": "^7.0"
  },
  "replace": {
    "hellogerard/jobby": "self.version"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "symfony/filesystem": "^2.7|^3.0|^4.0|^5.0|^6.0|^7.0"
  },
  "autoload": {
    "psr-4": {
      "Jobby\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Jobby\\Tests\\": "tests"
    }
  },
  "support": {
    "issues": "https://github.com/Y0lk/jobby/issues",
    "source": "https://github.com/Y0lk/jobby"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "4.x-dev"
    }
  },
  "config": {
    "sort-packages": true
  }
}
